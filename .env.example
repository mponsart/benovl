# ─── Base de données ──────────────────────────────────────────────────────────

# --- SQLite local (par défaut, aucune installation requise) ---
DATABASE_URL="file:./dev.db"

# --- Turso / LibSQL (pour Vercel – décommentez et renseignez) ---
# DATABASE_URL="file:./dev.db"       # utilisé uniquement pour prisma migrate
# TURSO_DATABASE_URL="libsql://<db-name>-<org>.turso.io"
# TURSO_AUTH_TOKEN="<votre-token-turso>"

# --- MySQL (O2switch / prod locale – renseignez DATABASE_URL ci-dessous) ---
# DATABASE_URL="mysql://user:password@localhost:3306/benovl"
# (puis lancer: npm run build:mysql et npm run db:migrate:mysql)

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"

