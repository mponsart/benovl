generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

// Default datasource: SQLite for local dev and Turso/Vercel (LibSQL).
// For MySQL (O2switch), use: prisma generate --schema=prisma/schema.mysql.prisma
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Note: SQLite/LibSQL does not support native enum or JSON types.
// Enum-like fields are stored as String and validated at the application level.
// See types/index.ts for the union types used throughout the app.

model Pole {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  description   String?
  users         User[]
  slots         PlanningSlot[]
  announcements Announcement[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  password      String
  nom           String
  prenom        String
  telephone     String?
  /// admin | responsable | benevole
  role          String   @default("benevole")
  /// actif | suspendu
  status        String   @default("actif")
  notesInternes String?
  poleId        Int?
  pole          Pole?    @relation(fields: [poleId], references: [id])
  inviteToken   String?  @unique
  inviteExpiry  DateTime?
  resetToken    String?  @unique
  resetExpiry   DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  registrations PlanningRegistration[]
  documents     Document[]
  auditLogs     AuditLog[]   @relation("AuditUser")
  auditActions  AuditLog[]   @relation("AuditActor")
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PlanningSlot {
  id                      Int      @id @default(autoincrement())
  title                   String
  description             String?
  startAt                 DateTime
  endAt                   DateTime
  location                String?
  maxCapacity             Int      @default(10)
  poleId                  Int?
  pole                    Pole?    @relation(fields: [poleId], references: [id])
  openForSelfRegistration Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  registrations           PlanningRegistration[]
}

model PlanningRegistration {
  id        Int      @id @default(autoincrement())
  userId    Int
  slotId    Int
  /// inscrit | confirme | absent
  status    String   @default("inscrit")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slot      PlanningSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, slotId])
}

model Document {
  id        Int      @id @default(autoincrement())
  name      String
  filename  String
  /// attestation | convention | autre
  type      String   @default("autre")
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  size      Int?
  mimeType  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  /// global | pole
  type      String   @default("global")
  poleId    Int?
  pole      Pole?    @relation(fields: [poleId], references: [id])
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  actorId   Int?
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  targetId  Int?
  target    User?    @relation("AuditUser", fields: [targetId], references: [id], onDelete: SetNull)
  /// create | update | delete | login | logout | invite | password_reset
  action    String
  entity    String
  entityId  Int?
  /// Stored as JSON string
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}

